{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc"],
	"categories": {
		"correctness": "error"
	},
	"rules": {
		"unicorn/filename-case": [
			"error",
			{
				"case": "camelCase"
			}
		]
	},
	"env": {
		"builtin": true
	},
	"ignorePatterns": ["lib"]
}
