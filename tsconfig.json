{
	"compilerOptions": {
		"lib": ["ESNext", "ESNext.Array"],
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"outDir": "lib",
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"erasableSyntaxOnly": true,
		"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"declaration": true,
		"resolveJsonModule": true
	},
	"include": [
		"src/*.ts",
		"src/**/*.ts",
		"benchmark/*.ts",
		"tests/*.ts",
		"eslint.config.js"
	],
	"exclude": ["node_modules"]
}
