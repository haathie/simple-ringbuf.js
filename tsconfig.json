{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"lib": ["DOM", "ESNext"],
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"sourceMap": true,
		"declarationMap": true
	},
	"include": ["src/index.ts"],
	"exclude": ["node_modules", "dist"]
}
