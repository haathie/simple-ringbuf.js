{
	"name": "ringbuf.js",
	"version": "0.4.0",
	"description": "Wait-free thread-safe single-consumer single-producer ring buffer using SharedArrayBuffer.",
	"keywords": [
		"garbage collector",
		"ring buffer",
		"single-consumer",
		"single-producer",
		"wait-free"
	],
	"license": "MPL-2.0",
	"author": "Paul Adenot <padenot@mozilla.com>",
	"repository": "padenot/ringbuf.js",
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"lint": "oxlint -c .oxlintrc.json",
		"format": "oxfmt -c .oxfmtrc.json",
		"test": "node --test src/tests/test.ts"
	},
	"devDependencies": {
		"@types/node": "^24.13.2",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=24",
		"npm": ">=9"
	}
}
